<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="011-insert-channels-demo-webhook" author="dashboard-battle">
        <insert tableName="publish_channels">
            <column name="code" value="DEMO_PAGE"/>
            <column name="name" value="Демо-страница"/>
        </insert>
        <insert tableName="publish_channels">
            <column name="code" value="WEBHOOK"/>
            <column name="name" value="HTTP Webhook"/>
        </insert>
    </changeSet>

    <changeSet id="012-create-demo-page-snapshots" author="dashboard-battle">
        <createTable tableName="demo_page_snapshots">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="publication_id" type="BIGINT">
                <constraints nullable="false" unique="true"
                             foreignKeyName="fk_demo_snap_pub"
                             references="publications(id)" deleteCascade="true"/>
            </column>
            <column name="share_token" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="html_body" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="now()"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
